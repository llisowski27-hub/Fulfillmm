# ============================================================
# THE LIQUIDATOR — Production Environment Variables
# .env.production
# ============================================================
# Skopiuj na serwer i uzupełnij wartościami.
# NIE commituj tego pliku do repo.
# ============================================================

# ── Supabase (publiczne — trafiają do client bundle) ────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Supabase (prywatne — TYLKO server-side) ─────────────────
# Service role key — pełny dostęp, NIGDY nie expose do klienta.
# Używany w Server Actions do operacji administracyjnych.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── App ─────────────────────────────────────────────────────
# URL aplikacji (do redirectów, email linków)
NEXT_PUBLIC_APP_URL=https://twoja-domena.pl

# Port (domyślnie 3000)
PORT=3000

# Node environment
NODE_ENV=production
